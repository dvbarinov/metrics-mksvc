global:
  # SMTP настройки для отправки почты
  smtp_smarthost: '${SMTP_HOST}:${SMTP_PORT}'
  smtp_from: '${SMTP_FROM}'
  smtp_auth_username: '${SMTP_USER}'
  smtp_auth_password: '${SMTP_PASS}'
  smtp_require_tls: true

  # Slack webhook
  slack_api_url: '${SLACK_WEBHOOK_URL}'

  # Telegram bot
  telegram_api_url: 'https://api.telegram.org'

  # Время ожидания перед отправкой первого уведомления
  resolve_timeout: 5m

# Шаблоны для уведомлений
templates:
  - '/etc/alertmanager/templates/*.tmpl'

# Маршрутизация алертов
route:
  # Группировка алертов
  group_by: ['alertname', 'service', 'severity', 'region']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 3h

  # Получатель по умолчанию
  receiver: 'default-receiver'

  # Дочерние маршруты
  routes:
    # Критические алерты → срочные каналы
    - match:
        severity: 'critical'
      receiver: 'critical-alerts'
      group_wait: 10s
      repeat_interval: 15m

    # Предупреждения → обычные каналы
    - match:
        severity: 'warning'
      receiver: 'warning-alerts'
      group_wait: 1m

    # Информационные → логирование
    - match:
        severity: 'info'
      receiver: 'info-alerts'
      group_wait: 5m

# Получатели уведомлений
receivers:
  - name: 'default-receiver'
    email_configs:
      - to: '${SMTP_USER}'
        send_resolved: true
        html: '{{ template "email.default.html" . }}'
        headers:
          Subject: '[{{ .Status | toUpper }}] {{ .CommonLabels.alertname }}'

    slack_configs:
      - channel: '#alerts'
        send_resolved: true
        title: '{{ .Status | toUpper }}: {{ .CommonLabels.alertname }}'
        text: '{{ template "slack.default.text" . }}'
        username: 'Prometheus Alert'
        icon_emoji: ':warning:'

    webhook_configs:
      - url: 'http://localhost:9090/webhook'
        send_resolved: true

  - name: 'critical-alerts'
    email_configs:
      - to: '${SMTP_USER}'
        send_resolved: true
        html: '{{ template "email.critical.html" . }}'

    slack_configs:
      - channel: '#critical-alerts'
        send_resolved: true
        title: ':rotating_light: [CRITICAL] {{ .CommonLabels.alertname }}'
        text: '{{ template "slack.critical.text" . }}'
        username: '🚨 CRITICAL ALERT'
        icon_emoji: ':rotating_light:'

    pagerduty_configs:
      - routing_key: '${PAGERDUTY_ROUTING_KEY}'
        send_resolved: true

    telegram_configs:
      - bot_token: '${TELEGRAM_BOT_TOKEN}'
        chat_id: ${TELEGRAM_CHAT_ID}
        send_resolved: true
        message: '{{ template "telegram.critical" . }}'


  - name: 'warning-alerts'
    email_configs:
      - to: '${SMTP_USER}'
        send_resolved: true

    slack_configs:
      - channel: '#warnings'
        send_resolved: true
        title: ':warning: [WARNING] {{ .CommonLabels.alertname }}'
        text: '{{ template "slack.warning.text" . }}'

    telegram_configs:
      - bot_token: '${TELEGRAM_BOT_TOKEN}'
        chat_id: ${TELEGRAM_CHAT_ID}
        send_resolved: true
        message: '{{ template "telegram.warning" . }}'

    webhook_configs:
      - url: 'http://localhost:9090/webhook-warning'
        send_resolved: true

  - name: 'info-alerts'
    slack_configs:
      - channel: '#info'
        send_resolved: false
        title: ':information_source: [INFO] {{ .CommonLabels.alertname }}'
        text: '{{ template "slack.info.text" . }}'

# Подавление алертов (inhibition rules)
inhibit_rules:
  # Если сервис недоступен, подавлять все остальные алерты для него
  - source_match:
      alertname: 'ServiceDown'
    target_match_re:
      alertname: '.*'
    equal: ['service', 'instance']
  # Если есть критический алерт, подавлять предупреждения для того же сервиса
  - source_match:
      severity: 'critical'
    target_match:
      severity: 'warning'
    equal: ['service', 'instance']

